class Solution:
    def countStrings(self, n):
        # Base cases for n = 1
        # Strings: "0", "1" (Total 2)
        # For n = 2
        # Strings: "00", "01", "10" (Total 3)
        
        if n == 0: return 0
        
        # end_with_zero: count of valid strings ending in 0
        # end_with_one: count of valid strings ending in 1
        end_with_zero = 1
        end_with_one = 1
        
        for i in range(2, n + 1):
            # Strings ending in 0 can follow either 0 or 1
            # Strings ending in 1 can ONLY follow 0
            new_end_with_zero = end_with_zero + end_with_one
            new_end_with_one = end_with_zero
            
            end_with_zero = new_end_with_zero
            end_with_one = new_end_with_one
            
        return end_with_zero + end_with_one
