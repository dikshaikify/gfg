/**
 * @param {number[]} arr
 * @returns {number}
 */
class Solution {
    maxOnes(arr) {
        let countOnes = 0;

        // Count original 1s
        for (let num of arr) {
            if (num === 1) countOnes++;
        }

        // Kadane's Algorithm
        let currGain = 0;
        let maxGain = 0;

        for (let num of arr) {
            let value = (num === 0) ? 1 : -1;

            currGain = Math.max(value, currGain + value);
            maxGain = Math.max(maxGain, currGain);
        }

        return countOnes + maxGain;
    }
}
