import java.util.*;

class Solution {
    public ArrayList<Integer> reducePairs(int[] arr) {
        Stack<Integer> stack = new Stack<>();

        for (int curr : arr) {
            boolean destroyed = false;

            // Check for opposite signs: (a > 0 && b < 0) or (a < 0 && b > 0)
            while (!stack.isEmpty() && ((stack.peek() > 0 && curr < 0) || (stack.peek() < 0 && curr > 0))) {
                int top = stack.peek();
                int absTop = Math.abs(top);
                int absCurr = Math.abs(curr);

                if (absTop < absCurr) {
                    // Current is stronger, remove top and keep checking
                    stack.pop();
                    continue; 
                } else if (absTop == absCurr) {
                    // Both equal, both destroyed
                    stack.pop();
                    destroyed = true;
                    break;
                } else {
                    // Top is stronger, current destroyed
                    destroyed = true;
                    break;
                }
            }

            if (!destroyed) {
                stack.push(curr);
            }
        }

        return new ArrayList<>(stack);
    }
}
