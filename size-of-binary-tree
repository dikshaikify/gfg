class Solution {
    public int getSize(Node root) {
        // Base case: If the tree is empty, size is 0
        if (root == null) {
            return 0;
        }
        
        // Recursive call: 1 (for current node) + left child's subtree size + right child's subtree size
        return 1 + getSize(root.left) + getSize(root.right);
    }
}
