class Solution {
    public int minSwaps(int[] arr) {
        int n = arr.length;
        
        // Step 1: Count total number of 1s
        int ones = 0;
        for (int num : arr) {
            if (num == 1) ones++;
        }
        
        // Edge case: no 1s
        if (ones == 0) return -1;
        
        // Step 2: Sliding window of size 'ones'
        int currOnes = 0;
        
        // Initial window
        for (int i = 0; i < ones; i++) {
            if (arr[i] == 1) currOnes++;
        }
        
        int maxOnes = currOnes;
        
        // Slide the window
        for (int i = ones; i < n; i++) {
            if (arr[i] == 1) currOnes++;
            if (arr[i - ones] == 1) currOnes--;
            
            maxOnes = Math.max(maxOnes, currOnes);
        }
        
        // Minimum swaps needed
        return ones - maxOnes;
    }
}
