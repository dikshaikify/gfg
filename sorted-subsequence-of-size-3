import java.util.ArrayList;

class Solution {
    public ArrayList<Integer> find3Numbers(int[] arr) {
        int n = arr.length;
        ArrayList<Integer> result = new ArrayList<>();
        
        if (n < 3) return result;

        int[] leftMin = new int[n];
        int[] rightMax = new int[n];

        // Fill leftMin: stores index of the minimum element to the left
        leftMin[0] = 0;
        int minSoFar = 0;
        for (int i = 1; i < n; i++) {
            if (arr[i] <= arr[minSoFar]) {
                minSoFar = i;
            }
            leftMin[i] = minSoFar;
        }

        // Fill rightMax: stores index of the maximum element to the right
        rightMax[n - 1] = n - 1;
        int maxSoFar = n - 1;
        for (int i = n - 2; i >= 0; i--) {
            if (arr[i] >= arr[maxSoFar]) {
                maxSoFar = i;
            }
            rightMax[i] = maxSoFar;
        }

        // Traverse to find the triplet
        for (int i = 0; i < n; i++) {
            if (arr[leftMin[i]] < arr[i] && arr[i] < arr[rightMax[i]]) {
                result.add(arr[leftMin[i]]);
                result.add(arr[i]);
                result.add(arr[rightMax[i]]);
                return result; // Return the first valid triplet found
            }
        }

        return result; // Return empty list if no triplet exists
    }
}
