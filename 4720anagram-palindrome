//javascript//
class Solution {
    canFormPalindrome(s) {
        let freq = new Array(26).fill(0);

        for (let ch of s) {
            freq[ch.charCodeAt(0) - 97]++;
        }

        let oddCount = 0;

        for (let f of freq) {
            if (f % 2 !== 0) {
                oddCount++;
                if (oddCount > 1) return false; // early exit
            }
        }

        return true;
    }
}
