// python//
class Solution {
    boolean canFormPalindrome(String s) {
        int[] freq = new int[26];
        
        // Count frequency
        for (char c : s.toCharArray()) {
            freq[c - 'a']++;
        }
        
        int oddCount = 0;
        
        // Count odd frequencies
        for (int f : freq) {
            if (f % 2 != 0) {
                oddCount++;
            }
        }
        
        // Check condition
        return oddCount <= 1;
    }
}



